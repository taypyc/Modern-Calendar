# Neon Postgres: https://console.neon.tech → project → Connection string
# Use the pooled "Transaction" string for serverless, or direct — both work with this app.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Random secret for signing session cookies (min 32 chars). Example: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string-at-least-32-chars
